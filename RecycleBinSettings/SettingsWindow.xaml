<ui:FluentWindow x:Class="RecycleBinTaskbar.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Recycle Bin Shortcut Settings"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Recycle Bin Shortcut Settings"
                     ShowMaximize="False" ShowMinimize="True"/>

        <Grid Grid.Row="1" Margin="24,10,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Taskbar shortcut language" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,10"
                       Text="Choose the language used for the &quot;Empty Recycle Bin&quot; and &quot;Open Recycle Bin&quot; entries when you right-click the pinned taskbar icon."/>

            <ComboBox Grid.Row="2" x:Name="LanguageComboBox" DisplayMemberPath="NativeName"
                      Height="40" Padding="12,8" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Grid.Row="3" x:Name="StatusReadout" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,8"/>

            <ui:Button Grid.Row="4" x:Name="RefreshButton" Content="Refresh count" HorizontalAlignment="Left"
                       Height="30" Margin="0,0,0,15" Click="RefreshButton_Click"/>

            <TextBlock Grid.Row="5" Text="Emptying behavior" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="6" Margin="0,0,0,15">
                <CheckBox x:Name="ConfirmCheckBox" Content="Ask for confirmation before emptying" Margin="0,0,0,8"/>
                <CheckBox x:Name="SoundCheckBox" Content="Play a sound when emptying" Margin="0,0,0,8"/>
                <CheckBox x:Name="NotificationCheckBox" Content="Show a notification after emptying"/>
            </StackPanel>

            <TextBlock Grid.Row="7" x:Name="StatusText" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="ApplyButton" Content="Apply" Appearance="Primary" Width="100" Height="34" Margin="0,0,10,0" Click="ApplyButton_Click"/>
                <ui:Button x:Name="CloseButton" Content="Close" Width="100" Height="34" Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
